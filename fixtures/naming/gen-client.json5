// Demonstrates naming convention customization.
// You can use the **built** generator or debug the current generator source [e.g. npm run generator:dev -- -c fixtures/naming/gen-client.json5]
//      node dist/oag-generator.js --config fixtures/naming/gen-client.json5
{
	i: './fixtures/naming/naming.bundle.json',
	o: 'fixtures/naming/client-src',
	d: 'full',
	r: 'client',
	p: [
		'base.target="browser"',
		'tsmorph.client.httpsup="fetch"',
		// Directory naming
		'base.modelIntfDir="types"',
		'base.modelImplDir="dto"',
		'base.modelJsonDir="schema"',
		'base.apiIntfDir="api"',
		'base.apiImplDir="impl"',
		'base.apiMockDir="mock"',
		// File/class suffix and separator customization
		'base.fileSuffixSep="."',
		'base.modelIntfFileSuffix="model"',
		'base.apiIntfFileSuffix="api"',
		'base.implSuffix="DTO"',
		'base.implFileSuffix="dto"',
		'base.jsonSuffix="Schema"',
		'base.jsonFileSuffix="schema"',
		// Template-based file naming
		'base.implFileBasename_Tmpl="#{name}.#{implFileSuffix}"',
		'base.jsonFileBasename_Tmpl="#{name}.#{jsonFileSuffix}"'
	]
}
