# IntelliJ files
/.idea/workspace.xml
/.idea/dataSources.local.xml
/.idea/scopes

# Logs
logs
*.log
npm-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Dependency directories
node_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz
/dist/

# Ignore everything under fixtures/
fixtures/*
!fixtures/ReadMe.md

# Keep these fixtures directories
!fixtures/petstore-*/
!fixtures/petstore-*/**
fixtures/petstore-*/*.bundle.json
fixtures/petstore-*/client-*/
fixtures/petstore-*/server-*/

!fixtures/edge-cases/
!fixtures/edge-cases/**
!fixtures/naming/
!fixtures/naming/**
fixtures/naming/*.bundle.json
fixtures/naming/client-*/
